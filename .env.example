# ============================================
# NodePrism - Environment Configuration
# ============================================
# Copy this file to .env and modify as needed
# ============================================

# ==================== General ====================
NODE_ENV=development
LOG_LEVEL=info

# ==================== API Server ====================
API_PORT=4000
API_HOST=localhost

# ==================== Web UI ====================
WEB_PORT=3000
# Leave empty to use Next.js proxy (recommended for dev)
NEXT_PUBLIC_API_URL=

# ==================== Database (PostgreSQL) ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nodeprism
DB_USER=nodeprism
DB_PASSWORD=nodeprism123
# Full URL (auto-generated from above if not set)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Full URL (auto-generated from above if not set)
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ==================== RabbitMQ ====================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=nodeprism
RABBITMQ_PASSWORD=nodeprism123
# Full URL (auto-generated from above if not set)
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}

# ==================== Prometheus ====================
PROMETHEUS_HOST=localhost
PROMETHEUS_PORT=9090
PROMETHEUS_URL=http://${PROMETHEUS_HOST}:${PROMETHEUS_PORT}

# ==================== Loki ====================
LOKI_HOST=localhost
LOKI_PORT=3100
LOKI_URL=http://${LOKI_HOST}:${LOKI_PORT}

# ==================== Grafana ====================
GRAFANA_HOST=localhost
GRAFANA_PORT=3030
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_URL=http://${GRAFANA_HOST}:${GRAFANA_PORT}

# ==================== AlertManager ====================
ALERTMANAGER_HOST=localhost
ALERTMANAGER_PORT=9093
ALERTMANAGER_URL=http://${ALERTMANAGER_HOST}:${ALERTMANAGER_PORT}

# ==================== Authentication (JWT) ====================
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=7d

# ==================== CORS ====================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ==================== Status Sync ====================
# How often to sync server status from Prometheus (ms)
STATUS_SYNC_INTERVAL=30000

# ==================== Deployment Worker ====================
# SSH connection timeout (ms)
SSH_TIMEOUT=30000
# Default SSH user for deployments
DEFAULT_SSH_USER=root
