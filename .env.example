# ============================================
# NodePrism - Environment Configuration
# ============================================
# Copy this file to .env and modify as needed
# ============================================

# ==================== General ====================
NODE_ENV=development
LOG_LEVEL=info

# ==================== Server IP ====================
# Your server's public IP address
SERVER_IP=your-server-ip

# ==================== API Server ====================
API_PORT=4000
API_HOST=0.0.0.0

# ==================== Web UI ====================
WEB_PORT=3000
# Leave empty to use Next.js proxy (recommended for dev)
NEXT_PUBLIC_API_URL=

# ==================== Database (PostgreSQL) ====================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nodeprism
DB_USER=nodeprism
DB_PASSWORD=nodeprism123

# ==================== MySQL (Sample DB for Monitoring) ====================
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=nodeprism
MYSQL_USER=nodeprism
MYSQL_PASSWORD=nodeprism123

# ==================== MongoDB (Sample DB for Monitoring) ====================
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_ROOT_USERNAME=root
MONGODB_ROOT_PASSWORD=password
MONGODB_DATABASE=admin

# ==================== Redis ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== Prometheus ====================
PROMETHEUS_HOST=prometheus
PROMETHEUS_PORT=9090

# ==================== Loki ====================
LOKI_HOST=loki
LOKI_PORT=3100

# ==================== Grafana ====================
GRAFANA_HOST=grafana
GRAFANA_PORT=3030
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# ==================== AlertManager ====================
ALERTMANAGER_HOST=alertmanager
ALERTMANAGER_PORT=9093

# ==================== Authentication (JWT) ====================
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=7d

# ==================== CORS ====================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ==================== Status Sync ====================
# How often to sync server status from Prometheus (ms)
STATUS_SYNC_INTERVAL=30000

# ==================== Public URLs (for Web UI external links) ====================
# Relative paths - proxied through Next.js (recommended)
NEXT_PUBLIC_GRAFANA_URL=/grafana/
NEXT_PUBLIC_PROMETHEUS_URL=/prometheus/
NEXT_PUBLIC_ALERTMANAGER_URL=/alertmanager/
NEXT_PUBLIC_DOCS_URL=http://localhost:3080

# ==================== App URL ====================
# Full URL where the app is accessible (used for cookies, links)
APP_URL=http://your-server-ip:3000

# ==================== Daily Report ====================
DAILY_REPORT_TIME=08:00
# DAILY_REPORT_SLACK_WEBHOOK=https://hooks.slack.com/services/your/webhook/url
