{
  "annotations": { "list": [] },
  "description": "Anomaly detection monitoring - NAR scores, model counts, anomaly event timeline",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Anomaly Events (Last 7 Days)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('hour', started_at) AS time, COUNT(*) AS anomalies FROM anomaly_events WHERE started_at >= NOW() - INTERVAL '7 days' GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "bars", "fillOpacity": 30 }
        }
      }
    },
    {
      "title": "Active Anomaly Events",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Active Anomalies\" FROM anomaly_events WHERE ended_at IS NULL",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "Trained Models",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Trained Models\" FROM anomaly_models WHERE expires_at > NOW()",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none" }
      }
    },
    {
      "title": "Servers with Anomalies (24h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT server_id) AS \"Affected Servers\" FROM anomaly_events WHERE started_at >= NOW() - INTERVAL '24 hours'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Expired Models",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Expired Models\" FROM anomaly_models WHERE expires_at <= NOW()",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none" }
      }
    },
    {
      "title": "Anomaly Scores by Server (NAR)",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT s.hostname, COUNT(ae.id) AS total_anomalies, COUNT(CASE WHEN ae.ended_at IS NULL THEN 1 END) AS active, ROUND(AVG(ae.score)::numeric, 3) AS avg_score, ROUND(AVG(ae.severity)::numeric, 1) AS avg_nar_pct FROM anomaly_events ae JOIN servers s ON ae.server_id = s.id WHERE ae.started_at >= NOW() - INTERVAL '7 days' GROUP BY s.hostname ORDER BY active DESC, total_anomalies DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Top Anomalous Metrics",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT metric_name, COUNT(*) AS occurrences, ROUND(AVG(score)::numeric, 3) AS avg_score, ROUND(MAX(score)::numeric, 3) AS max_score FROM anomaly_events WHERE started_at >= NOW() - INTERVAL '7 days' GROUP BY metric_name ORDER BY occurrences DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Model Training Timeline",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('hour', trained_at) AS time, COUNT(*) AS models_trained, AVG(data_points) AS avg_data_points FROM anomaly_models WHERE trained_at >= NOW() - INTERVAL '7 days' GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none" }
      }
    },
    {
      "title": "Anomaly Duration Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('day', started_at) AS time, ROUND(AVG(EXTRACT(EPOCH FROM (COALESCE(ended_at, NOW()) - started_at)))::numeric, 0) AS avg_duration_seconds FROM anomaly_events WHERE started_at >= NOW() - INTERVAL '7 days' GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Models by Server",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT s.hostname AS metric, COUNT(am.id) AS \"Models\" FROM anomaly_models am JOIN servers s ON am.server_id = s.id WHERE am.expires_at > NOW() GROUP BY s.hostname ORDER BY COUNT(am.id) DESC LIMIT 15",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none" }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["nodeprism", "anomaly", "ml"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "title": "Anomaly Detection",
  "uid": "nodeprism-anomaly-detection"
}
