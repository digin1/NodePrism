        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(cpanel_accounts_total, hostname)",
        "includeAll": true,
        "multi": true,
        "name": "server",
        "query": "label_values(cpanel_accounts_total, hostname)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
