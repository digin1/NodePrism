{
  "annotations": { "list": [] },
  "description": "MongoDB monitoring - operations, connections, memory, replication",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Operations per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(mongodb_op_counters_total{job=\"mongodb-exporter\", type=\"insert\"}[5m])",
          "legendFormat": "insert",
          "refId": "A"
        },
        {
          "expr": "rate(mongodb_op_counters_total{job=\"mongodb-exporter\", type=\"query\"}[5m])",
          "legendFormat": "query",
          "refId": "B"
        },
        {
          "expr": "rate(mongodb_op_counters_total{job=\"mongodb-exporter\", type=\"update\"}[5m])",
          "legendFormat": "update",
          "refId": "C"
        },
        {
          "expr": "rate(mongodb_op_counters_total{job=\"mongodb-exporter\", type=\"delete\"}[5m])",
          "legendFormat": "delete",
          "refId": "D"
        },
        {
          "expr": "rate(mongodb_op_counters_total{job=\"mongodb-exporter\", type=\"command\"}[5m])",
          "legendFormat": "command",
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "mongodb_connections{job=\"mongodb-exporter\", state=\"current\"}",
          "legendFormat": "current",
          "refId": "A"
        },
        {
          "expr": "mongodb_connections{job=\"mongodb-exporter\", state=\"available\"}",
          "legendFormat": "available",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none" }
      }
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "mongodb_extra_info_heap_usage_bytes{job=\"mongodb-exporter\"}",
          "legendFormat": "heap",
          "refId": "A"
        },
        {
          "expr": "mongodb_mem_resident{job=\"mongodb-exporter\"} * 1024 * 1024",
          "legendFormat": "resident",
          "refId": "B"
        },
        {
          "expr": "mongodb_mem_virtual{job=\"mongodb-exporter\"} * 1024 * 1024",
          "legendFormat": "virtual",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Document Operations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(mongodb_metrics_document_total{job=\"mongodb-exporter\", state=\"returned\"}[5m])",
          "legendFormat": "returned",
          "refId": "A"
        },
        {
          "expr": "rate(mongodb_metrics_document_total{job=\"mongodb-exporter\", state=\"inserted\"}[5m])",
          "legendFormat": "inserted",
          "refId": "B"
        },
        {
          "expr": "rate(mongodb_metrics_document_total{job=\"mongodb-exporter\", state=\"updated\"}[5m])",
          "legendFormat": "updated",
          "refId": "C"
        },
        {
          "expr": "rate(mongodb_metrics_document_total{job=\"mongodb-exporter\", state=\"deleted\"}[5m])",
          "legendFormat": "deleted",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "WiredTiger Cache",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "mongodb_wiredtiger_cache_bytes{job=\"mongodb-exporter\", type=\"total\"}",
          "legendFormat": "cache total",
          "refId": "A"
        },
        {
          "expr": "mongodb_wiredtiger_cache_bytes{job=\"mongodb-exporter\", type=\"dirty\"}",
          "legendFormat": "dirty bytes",
          "refId": "B"
        },
        {
          "expr": "mongodb_wiredtiger_cache_max_bytes{job=\"mongodb-exporter\"}",
          "legendFormat": "cache max",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(mongodb_network_bytes_total{job=\"mongodb-exporter\", state=\"in_bytes\"}[5m])",
          "legendFormat": "in",
          "refId": "A"
        },
        {
          "expr": "rate(mongodb_network_bytes_total{job=\"mongodb-exporter\", state=\"out_bytes\"}[5m])",
          "legendFormat": "out",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Replication Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "mongodb_mongod_replset_member_optime_date{job=\"mongodb-exporter\", state=\"PRIMARY\"} - on() mongodb_mongod_replset_member_optime_date{job=\"mongodb-exporter\", state=\"SECONDARY\"}",
          "legendFormat": "replication lag",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Cursors Open",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "mongodb_metrics_cursor_open{job=\"mongodb-exporter\", state=\"total\"}",
          "legendFormat": "open cursors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none" }
      }
    },
    {
      "title": "Asserts Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(mongodb_asserts_total{job=\"mongodb-exporter\"}[5m])",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["nodeprism", "mongodb", "database"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "MongoDB Overview",
  "uid": "nodeprism-mongodb"
}
