{
  "annotations": { "list": [] },
  "description": "Network traffic monitoring - per-server bandwidth, top talkers, error rates",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Network Receive Rate (All Servers)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{job=\"node-exporter\", device!~\"lo|veth.*|br.*|docker.*\"}[5m])",
          "legendFormat": "{{hostname}} {{device}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Network Transmit Rate (All Servers)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_transmit_bytes_total{job=\"node-exporter\", device!~\"lo|veth.*|br.*|docker.*\"}[5m])",
          "legendFormat": "{{hostname}} {{device}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Top 10 Servers by Bandwidth (RX+TX)",
      "type": "bargauge",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, sum by(hostname) (rate(node_network_receive_bytes_total{job=\"node-exporter\", device!~\"lo|veth.*|br.*|docker.*\"}[5m]) + rate(node_network_transmit_bytes_total{job=\"node-exporter\", device!~\"lo|veth.*|br.*|docker.*\"}[5m])))",
          "legendFormat": "{{hostname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50000000 },
              { "color": "red", "value": 100000000 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Total Bandwidth (Cluster)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_bytes_total{job=\"node-exporter\", device!~\"lo|veth.*|br.*|docker.*\"}[5m]) + rate(node_network_transmit_bytes_total{job=\"node-exporter\", device!~\"lo|veth.*|br.*|docker.*\"}[5m]))",
          "legendFormat": "total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Total Received (24h)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(node_network_receive_bytes_total{job=\"node-exporter\", device!~\"lo|veth.*|br.*|docker.*\"}[24h]))",
          "legendFormat": "rx 24h",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Total Transmitted (24h)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(node_network_transmit_bytes_total{job=\"node-exporter\", device!~\"lo|veth.*|br.*|docker.*\"}[24h]))",
          "legendFormat": "tx 24h",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Network Errors",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_errs_total{job=\"node-exporter\"}[5m]) + rate(node_network_transmit_errs_total{job=\"node-exporter\"}[5m]))",
          "legendFormat": "errors/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Packet Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_receive_errs_total{job=\"node-exporter\", device!~\"lo|veth.*\"}[5m])",
          "legendFormat": "{{hostname}} {{device}} rx errors",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_errs_total{job=\"node-exporter\", device!~\"lo|veth.*\"}[5m])",
          "legendFormat": "{{hostname}} {{device}} tx errors",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "pps" }
      }
    },
    {
      "title": "Packet Drop Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_receive_drop_total{job=\"node-exporter\", device!~\"lo|veth.*\"}[5m])",
          "legendFormat": "{{hostname}} {{device}} rx drops",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_drop_total{job=\"node-exporter\", device!~\"lo|veth.*\"}[5m])",
          "legendFormat": "{{hostname}} {{device}} tx drops",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "pps" }
      }
    },
    {
      "title": "TCP Connections by State",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by(state) (node_tcp_connection_states{job=\"node-exporter\"})",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none" }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["nodeprism", "network", "traffic"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Network Traffic",
  "uid": "nodeprism-network-traffic"
}
