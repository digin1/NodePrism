{
  "annotations": { "list": [] },
  "description": "PostgreSQL database monitoring - connections, queries, locks, replication",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres-exporter\", state=\"active\"}",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "pg_stat_activity_count{job=\"postgres-exporter\", state=\"idle\"}",
          "legendFormat": "idle",
          "refId": "B"
        },
        {
          "expr": "pg_stat_activity_count{job=\"postgres-exporter\", state=\"idle in transaction\"}",
          "legendFormat": "idle in txn",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none" }
      }
    },
    {
      "title": "Connection Usage %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count{job=\"postgres-exporter\"}) / pg_settings_max_connections{job=\"postgres-exporter\"} * 100",
          "legendFormat": "usage",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Max Connections",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_settings_max_connections{job=\"postgres-exporter\"}",
          "legendFormat": "max",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none" }
      }
    },
    {
      "title": "Transactions per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "{{datname}} commits/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "{{datname}} rollbacks/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Rows Operations per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_fetched{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "{{datname}} fetched",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_tup_inserted{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "{{datname}} inserted",
          "refId": "B"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "{{datname}} updated",
          "refId": "C"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "{{datname}} deleted",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Database Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_database_size_bytes{job=\"postgres-exporter\"}",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Locks by Mode",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_locks_count{job=\"postgres-exporter\"}",
          "legendFormat": "{{datname}} {{mode}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none" }
      }
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{job=\"postgres-exporter\"} / (pg_stat_database_blks_hit{job=\"postgres-exporter\"} + pg_stat_database_blks_read{job=\"postgres-exporter\"}) * 100",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "title": "Deadlocks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_deadlocks{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Replication Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_replication_lag{job=\"postgres-exporter\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["nodeprism", "postgresql", "database"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "PostgreSQL Overview",
  "uid": "nodeprism-postgresql"
}
