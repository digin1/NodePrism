{
  "name": "@veeble/agent-app",
  "version": "1.0.0",
  "private": true,
  "description": "Custom application monitoring agent",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "pkg": "pkg dist/index.js -t node20-linux-x64 -o ../../agents/app-agent/veeble-agent",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@veeble/shared": "workspace:*",
    "express": "^4.18.2",
    "prom-client": "^15.1.0",
    "dotenv": "^16.4.1",
    "winston": "^3.11.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "pkg": "^5.8.1"
  }
}
