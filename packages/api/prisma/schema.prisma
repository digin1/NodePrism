// NodePrism - Database Schema
// This schema defines all tables for the monitoring system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== SERVER GROUP MANAGEMENT ====================

model ServerGroup {
  id          String        @id @default(uuid())
  name        String
  description String?
  parentId    String?       @map("parent_id")
  sortOrder   Int           @default(0) @map("sort_order")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Self-referencing hierarchy
  parent   ServerGroup?  @relation("GroupHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children ServerGroup[] @relation("GroupHierarchy")

  // Servers in this group
  servers Server[]

  @@map("server_groups")
}

// ==================== SERVER MANAGEMENT ====================

model Server {
  id          String       @id @default(uuid())
  hostname    String
  ipAddress   String       @map("ip_address")
  status      ServerStatus @default(OFFLINE)
  environment Environment  @default(PRODUCTION)
  groupId     String?      @map("group_id")
  region      String?
  tags        String[]     @default([])
  metadata    Json?
  lastSeen    DateTime?    @map("last_seen")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  group              ServerGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  agents             Agent[]
  virtualContainers  VirtualContainer[]
  alerts             Alert[]
  anomalyEvents      AnomalyEvent[]
  anomalyModels      AnomalyModel[]
  metricHistory      MetricHistory[]
  eventLogs          EventLog[]
  maintenanceWindows MaintenanceWindow[]
  uptimeMonitors     UptimeMonitor[]
  incidents          Incident[]

  @@map("servers")
}

enum ServerStatus {
  ONLINE
  OFFLINE
  WARNING
  CRITICAL
}

enum Environment {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

// ==================== VIRTUAL CONTAINERS ====================

model VirtualContainer {
  id            String    @id @default(uuid())
  serverId      String    @map("server_id")
  containerId   String    @map("container_id")  // CTID for OpenVZ, UUID for KVM
  name          String                           // VM/container name
  type          String                           // openvz, kvm, virtuozzo, docker, lxc
  status        String    @default("unknown")    // running, stopped, paused, etc.
  ipAddress     String?   @map("ip_address")
  hostname      String?
  networkRxBytes BigInt   @default(0) @map("network_rx_bytes")
  networkTxBytes BigInt   @default(0) @map("network_tx_bytes")
  metadata      Json?                            // Extra info (vCPUs, memory, interfaces)
  lastSeen      DateTime? @map("last_seen")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, containerId])
  @@index([serverId])
  @@map("virtual_containers")
}

// ==================== AGENT MANAGEMENT ====================

model Agent {
  id              String      @id @default(uuid())
  serverId        String      @map("server_id")
  type            AgentType
  status          AgentStatus @default(NOT_INSTALLED)
  version         String?
  port            Int
  config          Json?
  lastHealthCheck DateTime?   @map("last_health_check")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  // Relations
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, type])
  @@map("agents")
}

enum AgentType {
  NODE_EXPORTER
  APP_AGENT
  MYSQL_EXPORTER
  POSTGRES_EXPORTER
  MONGODB_EXPORTER
  NGINX_EXPORTER
  APACHE_EXPORTER
  REDIS_EXPORTER
  LIBVIRT_EXPORTER
  LITESPEED_EXPORTER
  EXIM_EXPORTER
  CPANEL_EXPORTER
  PROMTAIL
}

enum AgentStatus {
  NOT_INSTALLED
  INSTALLING
  RUNNING
  STOPPED
  FAILED
  UPDATING
}

// ==================== ALERT MANAGEMENT ====================

model AlertRule {
  id          String        @id @default(uuid())
  name        String
  description String?
  query       String        // PromQL query
  duration    String        @default("5m")
  severity    AlertSeverity
  labels      Json?
  annotations Json?
  enabled     Boolean       @default(true)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  alerts Alert[]

  @@map("alert_rules")
}

model Alert {
  id          String        @id @default(uuid())
  ruleId      String?       @map("rule_id")
  templateId  String?       @map("template_id")
  serverId    String?       @map("server_id")
  status      AlertStatus   @default(FIRING)
  severity    AlertSeverity
  message     String
  labels      Json?
  annotations Json?
  fingerprint String        @unique
  startsAt    DateTime      @map("starts_at")
  endsAt      DateTime?     @map("ends_at")
  acknowledgedAt DateTime?  @map("acknowledged_at")
  acknowledgedBy String?    @map("acknowledged_by")
  createdAt   DateTime      @default(now()) @map("created_at")

  // Relations
  rule     AlertRule?     @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  template AlertTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  server   Server?        @relation(fields: [serverId], references: [id], onDelete: SetNull)

  @@map("alerts")
}

model AlertTemplate {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  // Matching criteria
  matchLabels     Json? // Record<string, string>
  matchHostLabels Json? // Record<string, string>
  // Alert configuration
  query           String // PromQL query
  calc            String? // Additional calculation expression
  units           String?
  // Thresholds with hysteresis
  warnCondition   Json? // { condition: string, hysteresis?: { trigger: number, clear: number } }
  critCondition   Json? // { condition: string, hysteresis?: { trigger: number, clear: number } }
  // Timing
  every           String   @default("1m") // Evaluation interval
  for             String   @default("5m") // Duration before firing
  // Actions
  actions         Json? // AlertAction[]
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  alerts Alert[]

  @@map("alert_templates")
}

enum AlertSeverity {
  CRITICAL
  WARNING
  INFO
  DEBUG
}

enum AlertStatus {
  CLEAR
  WARNING
  CRITICAL
  UNDEFINED
  PENDING
  FIRING
  RESOLVED
  SILENCED
  ACKNOWLEDGED
}

// ==================== NOTIFICATION CHANNELS ====================

model NotificationChannel {
  id        String                  @id @default(uuid())
  name      String
  type      NotificationChannelType
  config    Json
  enabled   Boolean                 @default(true)
  createdAt DateTime                @default(now()) @map("created_at")
  updatedAt DateTime                @updatedAt @map("updated_at")

  logs NotificationLog[]

  @@map("notification_channels")
}

model NotificationLog {
  id        String   @id @default(uuid())
  channelId String   @map("channel_id")
  alertId   String   @map("alert_id")
  status    String   // SUCCESS, FAILED
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  channel NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([createdAt])
  @@map("notification_logs")
}

enum NotificationChannelType {
  EMAIL
  SLACK
  DISCORD
  WEBHOOK
  PAGERDUTY
  TELEGRAM
}

// ==================== USER MANAGEMENT ====================

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  passwordHash String    @map("password_hash")
  role         UserRole  @default(VIEWER)
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  auditLogs AuditLog[]

  @@map("users")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  details    Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ==================== DASHBOARD CONFIGURATION ====================

model Dashboard {
  id          String   @id @default(uuid())
  name        String
  description String?
  config      Json     // Dashboard JSON configuration
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("dashboards")
}

// ==================== SYSTEM SETTINGS ====================

model SystemSettings {
  id            String   @id @default("default")
  systemName    String   @default("NodePrism") @map("system_name")
  logoPath      String?  @map("logo_path") // Path to uploaded logo
  logoUrl       String?  @map("logo_url") // URL for logo (if external)
  primaryColor  String   @default("#3B82F6") @map("primary_color")
  managerHostname String? @map("manager_hostname")
  managerIp     String?  @map("manager_ip")
  timezone      String   @default("UTC")
  dateFormat    String   @default("YYYY-MM-DD") @map("date_format")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ==================== MAINTENANCE WINDOWS ====================

model MaintenanceWindow {
  id        String   @id @default(uuid())
  serverId  String   @map("server_id")
  reason    String
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([startTime, endTime])
  @@map("maintenance_windows")
}

// ==================== METRICS HISTORY ====================

model MetricHistory {
  id         String   @id @default(uuid())
  serverId   String   @map("server_id")
  metricName String   @map("metric_name")
  value      Float
  timestamp  DateTime
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, metricName, timestamp])
  @@index([timestamp])
  @@map("metric_history")
}

// ==================== MONITORING EVENTS ====================

model EventLog {
  id         String        @id @default(uuid())
  serverId   String?       @map("server_id")
  type       EventType
  severity   EventSeverity @default(INFO)
  title      String
  message    String
  metadata   Json?         // Additional context (metrics, thresholds, etc.)
  source     String?       // Where the event originated (heartbeat, alert, agent, etc.)
  createdAt  DateTime      @default(now()) @map("created_at")

  // Relations
  server Server? @relation(fields: [serverId], references: [id], onDelete: SetNull)

  @@index([serverId, createdAt])
  @@index([type, createdAt])
  @@index([severity, createdAt])
  @@index([createdAt])
  @@map("event_logs")
}

enum EventType {
  // Availability events
  SERVER_ONLINE
  SERVER_OFFLINE
  SERVER_WARNING
  SERVER_CRITICAL
  SERVER_RECOVERED

  // Agent events
  AGENT_INSTALLED
  AGENT_STARTED
  AGENT_STOPPED
  AGENT_FAILED
  AGENT_UPDATED

  // Alert events
  ALERT_TRIGGERED
  ALERT_RESOLVED
  ALERT_ACKNOWLEDGED

  // Threshold events
  THRESHOLD_WARNING
  THRESHOLD_CRITICAL
  THRESHOLD_CLEARED

  // Anomaly events
  ANOMALY_DETECTED
  ANOMALY_RESOLVED

  // System events
  SYSTEM_STARTUP
  SYSTEM_SHUTDOWN
  HEARTBEAT_MISSED
  CONNECTION_LOST
  CONNECTION_RESTORED
}

enum EventSeverity {
  DEBUG
  INFO
  WARNING
  CRITICAL
}

// ==================== ANOMALY DETECTION ====================

// ==================== UPTIME MONITORING ====================

model UptimeMonitor {
  id          String            @id @default(uuid())
  name        String
  type        UptimeCheckType   @default(HTTP)
  target      String            // URL, hostname:port, or IP
  interval    Int               @default(60) // Check interval in seconds
  timeout     Int               @default(10) // Timeout in seconds
  method      String            @default("GET") // HTTP method
  expectedStatus Int?           @map("expected_status") // Expected HTTP status code
  keyword     String?           // Keyword to search for in response
  headers     Json?             // Custom headers for HTTP checks
  enabled     Boolean           @default(true)
  serverId    String?           @map("server_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  // Relations
  server Server? @relation(fields: [serverId], references: [id], onDelete: SetNull)
  checks UptimeCheck[]

  @@map("uptime_monitors")
}

model UptimeCheck {
  id          String    @id @default(uuid())
  monitorId   String    @map("monitor_id")
  status      UptimeCheckStatus
  responseTime Int?     @map("response_time") // Response time in ms
  statusCode  Int?      @map("status_code")
  message     String?
  checkedAt   DateTime  @default(now()) @map("checked_at")

  // Relations
  monitor UptimeMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, checkedAt])
  @@index([checkedAt])
  @@map("uptime_checks")
}

enum UptimeCheckType {
  HTTP
  HTTPS
  TCP
  PING
  DNS
}

enum UptimeCheckStatus {
  UP
  DOWN
  DEGRADED
}

// ==================== INCIDENT MANAGEMENT ====================

model Incident {
  id          String          @id @default(uuid())
  title       String
  description String?
  status      IncidentStatus  @default(INVESTIGATING)
  severity    AlertSeverity
  alertId     String?         @map("alert_id")
  serverId    String?         @map("server_id")
  assignee    String?
  startedAt   DateTime        @default(now()) @map("started_at")
  resolvedAt  DateTime?       @map("resolved_at")
  createdBy   String?         @map("created_by")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Relations
  server  Server?          @relation(fields: [serverId], references: [id], onDelete: SetNull)
  updates IncidentUpdate[]

  @@index([status])
  @@index([startedAt])
  @@map("incidents")
}

model IncidentUpdate {
  id          String   @id @default(uuid())
  incidentId  String   @map("incident_id")
  message     String
  status      IncidentStatus?
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, createdAt])
  @@map("incident_updates")
}

enum IncidentStatus {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
  POSTMORTEM
}

// ==================== ANOMALY DETECTION ====================

model AnomalyEvent {
  id         String    @id @default(uuid())
  serverId   String    @map("server_id")
  metricName String    @map("metric_name")
  score      Float
  severity   Float     // Percentage of metrics anomalous (NAR)
  startedAt  DateTime  @map("started_at")
  endedAt    DateTime? @map("ended_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  // Relations
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, startedAt])
  @@index([metricName])
  @@map("anomaly_events")
}

model AnomalyModel {
  id             String   @id @default(uuid())
  serverId       String   @map("server_id")
  metricName     String   @map("metric_name")
  clusterCenters Json     @map("cluster_centers")
  threshold      Float
  trainedAt      DateTime @map("trained_at")
  expiresAt      DateTime @map("expires_at")
  dataPoints     Int      @map("data_points")
  modelVersion   Int      @default(1) @map("model_version")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, metricName])
  @@index([serverId, metricName])
  @@map("anomaly_models")
}
