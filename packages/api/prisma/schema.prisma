// NodePrism - Database Schema
// This schema defines all tables for the monitoring system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== SERVER GROUP MANAGEMENT ====================

model ServerGroup {
  id          String        @id @default(uuid())
  name        String
  description String?
  parentId    String?       @map("parent_id")
  sortOrder   Int           @default(0) @map("sort_order")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Self-referencing hierarchy
  parent   ServerGroup?  @relation("GroupHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children ServerGroup[] @relation("GroupHierarchy")

  // Servers in this group
  servers Server[]

  @@map("server_groups")
}

// ==================== SERVER MANAGEMENT ====================

model Server {
  id          String       @id @default(uuid())
  hostname    String
  ipAddress   String       @map("ip_address")
  status      ServerStatus @default(OFFLINE)
  environment Environment  @default(PRODUCTION)
  groupId     String?      @map("group_id")
  region      String?
  tags        String[]     @default([])
  metadata    Json?
  lastSeen    DateTime?    @map("last_seen")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  group              ServerGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  agents             Agent[]
  virtualContainers  VirtualContainer[]
  alerts             Alert[]
  anomalyEvents      AnomalyEvent[]
  anomalyModels      AnomalyModel[]
  metricHistory      MetricHistory[]
  eventLogs          EventLog[]
  maintenanceWindows MaintenanceWindow[]
  uptimeMonitors     UptimeMonitor[]
  incidents          Incident[]
  infraChanges       InfraChange[]

  @@map("servers")
}

enum ServerStatus {
  ONLINE
  OFFLINE
  WARNING
  CRITICAL
}

enum Environment {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

// ==================== VIRTUAL CONTAINERS ====================

model VirtualContainer {
  id            String    @id @default(uuid())
  serverId      String    @map("server_id")
  containerId   String    @map("container_id")  // CTID for OpenVZ, UUID for KVM
  name          String                           // VM/container name
  type          String                           // openvz, kvm, virtuozzo, docker, lxc
  status        String    @default("unknown")    // running, stopped, paused, etc.
  ipAddress     String?   @map("ip_address")
  hostname      String?
  networkRxBytes BigInt   @default(0) @map("network_rx_bytes")
  networkTxBytes BigInt   @default(0) @map("network_tx_bytes")
  metadata      Json?                            // Extra info (vCPUs, memory, interfaces)
  lastSeen      DateTime? @map("last_seen")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, containerId])
  @@index([serverId])
  @@map("virtual_containers")
}

// ==================== AGENT MANAGEMENT ====================

model Agent {
  id              String      @id @default(uuid())
  serverId        String      @map("server_id")
  type            AgentType
  status          AgentStatus @default(NOT_INSTALLED)
  version         String?
  port            Int
  config          Json?
  lastHealthCheck DateTime?   @map("last_health_check")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  // Relations
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, type])
  @@map("agents")
}

enum AgentType {
  NODE_EXPORTER
  APP_AGENT
  MYSQL_EXPORTER
  POSTGRES_EXPORTER
  MONGODB_EXPORTER
  NGINX_EXPORTER
  APACHE_EXPORTER
  REDIS_EXPORTER
  LIBVIRT_EXPORTER
  LITESPEED_EXPORTER
  EXIM_EXPORTER
  CPANEL_EXPORTER
  PROMTAIL
}

enum AgentStatus {
  NOT_INSTALLED
  INSTALLING
  RUNNING
  STOPPED
  FAILED
  UPDATING
}

// ==================== ALERT MANAGEMENT ====================

model AlertRule {
  id          String        @id @default(uuid())
  name        String
  description String?
  query       String        // PromQL query
  duration    String        @default("5m")
  severity    AlertSeverity
  labels      Json?
  annotations Json?
  enabled     Boolean       @default(true)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  alerts Alert[]

  @@index([enabled])
  @@map("alert_rules")
}

model Alert {
  id          String        @id @default(uuid())
  ruleId      String?       @map("rule_id")
  templateId  String?       @map("template_id")
  serverId    String?       @map("server_id")
  status      AlertStatus   @default(FIRING)
  severity    AlertSeverity
  message     String
  labels      Json?
  annotations Json?
  fingerprint String        @unique
  startsAt    DateTime      @map("starts_at")
  endsAt      DateTime?     @map("ends_at")
  acknowledgedAt DateTime?  @map("acknowledged_at")
  acknowledgedBy String?    @map("acknowledged_by")
  isFlapping  Boolean       @default(false) @map("is_flapping")
  groupId     String?       @map("group_id")
  createdAt   DateTime      @default(now()) @map("created_at")

  // Relations
  rule     AlertRule?     @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  template AlertTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  server   Server?        @relation(fields: [serverId], references: [id], onDelete: SetNull)
  group    AlertGroup?    @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([status, severity])
  @@index([serverId])
  @@index([serverId, status])
  @@index([startsAt])
  @@index([createdAt])
  @@index([groupId])
  @@map("alerts")
}

model AlertTemplate {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  // Matching criteria
  matchLabels     Json? // Record<string, string>
  matchHostLabels Json? // Record<string, string>
  // Alert configuration
  query           String // PromQL query
  calc            String? // Additional calculation expression
  units           String?
  // Thresholds with hysteresis
  warnCondition   Json? // { condition: string, hysteresis?: { trigger: number, clear: number } }
  critCondition   Json? // { condition: string, hysteresis?: { trigger: number, clear: number } }
  // Timing
  every           String   @default("1m") // Evaluation interval
  for             String   @default("5m") // Duration before firing
  // Actions
  actions         Json? // AlertAction[]
  enabled         Boolean  @default(true)
  runbookId       String?  @map("runbook_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  alerts  Alert[]
  runbook Runbook? @relation(fields: [runbookId], references: [id], onDelete: SetNull)

  @@map("alert_templates")
}

enum AlertSeverity {
  CRITICAL
  WARNING
  INFO
  DEBUG
}

enum AlertStatus {
  CLEAR
  WARNING
  CRITICAL
  UNDEFINED
  PENDING
  FIRING
  RESOLVED
  SILENCED
  ACKNOWLEDGED
}

// ==================== NOTIFICATION CHANNELS ====================

model NotificationChannel {
  id        String                  @id @default(uuid())
  name      String
  type      NotificationChannelType
  config    Json
  enabled   Boolean                 @default(true)
  createdAt DateTime                @default(now()) @map("created_at")
  updatedAt DateTime                @updatedAt @map("updated_at")

  logs            NotificationLog[]
  escalationSteps EscalationStep[]

  @@map("notification_channels")
}

model NotificationLog {
  id        String   @id @default(uuid())
  channelId String   @map("channel_id")
  alertId   String   @map("alert_id")
  status    String   // SUCCESS, FAILED
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  channel NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([alertId])
  @@index([createdAt])
  @@map("notification_logs")
}

enum NotificationChannelType {
  EMAIL
  SLACK
  DISCORD
  WEBHOOK
  PAGERDUTY
  TELEGRAM
}

// ==================== USER MANAGEMENT ====================

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  passwordHash String    @map("password_hash")
  role         UserRole  @default(VIEWER)
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  auditLogs AuditLog[]
  apiTokens ApiToken[]

  @@map("users")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  details    Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ==================== DASHBOARD CONFIGURATION ====================

model Dashboard {
  id          String   @id @default(uuid())
  name        String
  description String?
  config      Json     // Dashboard JSON configuration
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("dashboards")
}

// ==================== SYSTEM SETTINGS ====================

model SystemSettings {
  id            String   @id @default("default")
  systemName    String   @default("NodePrism") @map("system_name")
  logoPath      String?  @map("logo_path") // Path to uploaded logo
  logoUrl       String?  @map("logo_url") // URL for logo (if external)
  primaryColor  String   @default("#3B82F6") @map("primary_color")
  managerHostname String? @map("manager_hostname")
  managerIp     String?  @map("manager_ip")
  timezone      String   @default("UTC")
  dateFormat    String   @default("YYYY-MM-DD") @map("date_format")
  dailyReportTime String @default("08:00") @map("daily_report_time")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ==================== MAINTENANCE WINDOWS ====================

model MaintenanceWindow {
  id              String   @id @default(uuid())
  serverId        String?  @map("server_id")
  uptimeMonitorId String?  @map("uptime_monitor_id")
  scope           String   @default("SERVER") // SERVER, MONITOR, GLOBAL
  reason          String
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  recurring       Boolean  @default(false)
  rrule           String?  // iCalendar RRULE for recurrence
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  server        Server?        @relation(fields: [serverId], references: [id], onDelete: Cascade)
  uptimeMonitor UptimeMonitor? @relation(fields: [uptimeMonitorId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([uptimeMonitorId])
  @@index([startTime, endTime])
  @@map("maintenance_windows")
}

// ==================== METRICS HISTORY ====================

model MetricHistory {
  id         String   @id @default(uuid())
  serverId   String   @map("server_id")
  metricName String   @map("metric_name")
  value      Float
  timestamp  DateTime
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, metricName, timestamp])
  @@index([serverId, timestamp])
  @@index([timestamp])
  @@map("metric_history")
}

// ==================== MONITORING EVENTS ====================

model EventLog {
  id         String        @id @default(uuid())
  serverId   String?       @map("server_id")
  type       EventType
  severity   EventSeverity @default(INFO)
  title      String
  message    String
  metadata   Json?         // Additional context (metrics, thresholds, etc.)
  source     String?       // Where the event originated (heartbeat, alert, agent, etc.)
  createdAt  DateTime      @default(now()) @map("created_at")

  // Relations
  server Server? @relation(fields: [serverId], references: [id], onDelete: SetNull)

  @@index([serverId, createdAt])
  @@index([type, createdAt])
  @@index([severity, createdAt])
  @@index([createdAt])
  @@map("event_logs")
}

enum EventType {
  // Availability events
  SERVER_ONLINE
  SERVER_OFFLINE
  SERVER_WARNING
  SERVER_CRITICAL
  SERVER_RECOVERED

  // Agent events
  AGENT_INSTALLED
  AGENT_STARTED
  AGENT_STOPPED
  AGENT_FAILED
  AGENT_UPDATED

  // Alert events
  ALERT_TRIGGERED
  ALERT_RESOLVED
  ALERT_ACKNOWLEDGED

  // Threshold events
  THRESHOLD_WARNING
  THRESHOLD_CRITICAL
  THRESHOLD_CLEARED

  // Anomaly events
  ANOMALY_DETECTED
  ANOMALY_RESOLVED

  // System events
  SYSTEM_STARTUP
  SYSTEM_SHUTDOWN
  HEARTBEAT_MISSED
  CONNECTION_LOST
  CONNECTION_RESTORED
}

enum EventSeverity {
  DEBUG
  INFO
  WARNING
  CRITICAL
}

// ==================== ANOMALY DETECTION ====================

// ==================== UPTIME MONITORING ====================

model UptimeMonitor {
  id          String            @id @default(uuid())
  name        String
  type        UptimeCheckType   @default(HTTP)
  target      String            // URL, hostname:port, or IP
  interval    Int               @default(60) // Check interval in seconds
  timeout     Int               @default(10) // Timeout in seconds
  method      String            @default("GET") // HTTP method
  expectedStatus Int?           @map("expected_status") // Expected HTTP status code
  keyword     String?           // Keyword to search for in response
  headers     Json?             // Custom headers for HTTP checks
  enabled     Boolean           @default(true)
  serverId    String?           @map("server_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  // Relations
  server             Server?             @relation(fields: [serverId], references: [id], onDelete: SetNull)
  checks             UptimeCheck[]
  slaPolicies        SlaPolicy[]
  maintenanceWindows MaintenanceWindow[]

  @@map("uptime_monitors")
}

model UptimeCheck {
  id           String    @id @default(uuid())
  monitorId    String    @map("monitor_id")
  status       UptimeCheckStatus
  responseTime Int?      @map("response_time") // Response time in ms
  statusCode   Int?      @map("status_code")
  message      String?
  certExpiry   DateTime? @map("cert_expiry")
  certIssuer   String?   @map("cert_issuer")
  domainExpiry DateTime? @map("domain_expiry")
  probeLabel   String?   @map("probe_label")
  checkedAt    DateTime  @default(now()) @map("checked_at")

  // Relations
  monitor UptimeMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, checkedAt])
  @@index([checkedAt])
  @@map("uptime_checks")
}

enum UptimeCheckType {
  HTTP
  HTTPS
  TCP
  PING
  DNS
  SSL_CERT
  DOMAIN
}

enum UptimeCheckStatus {
  UP
  DOWN
  DEGRADED
}

// ==================== INCIDENT MANAGEMENT ====================

model Incident {
  id          String          @id @default(uuid())
  title       String
  description String?
  status      IncidentStatus  @default(INVESTIGATING)
  severity    AlertSeverity
  alertId     String?         @map("alert_id")
  serverId    String?         @map("server_id")
  assignee      String?
  startedAt     DateTime        @default(now()) @map("started_at")
  resolvedAt    DateTime?       @map("resolved_at")
  createdBy     String?         @map("created_by")
  aiAnalysis    String?         @map("ai_analysis")
  aiAnalyzedAt  DateTime?       @map("ai_analyzed_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Relations
  server     Server?          @relation(fields: [serverId], references: [id], onDelete: SetNull)
  updates    IncidentUpdate[]
  postMortem PostMortem?

  @@index([status])
  @@index([startedAt])
  @@map("incidents")
}

model IncidentUpdate {
  id          String   @id @default(uuid())
  incidentId  String   @map("incident_id")
  message     String
  status      IncidentStatus?
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, createdAt])
  @@map("incident_updates")
}

enum IncidentStatus {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
  POSTMORTEM
}

// ==================== ANOMALY DETECTION ====================

model AnomalyEvent {
  id         String    @id @default(uuid())
  serverId   String    @map("server_id")
  metricName String    @map("metric_name")
  score      Float
  severity   Float     // Percentage of metrics anomalous (NAR)
  startedAt  DateTime  @map("started_at")
  endedAt    DateTime? @map("ended_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  // Relations
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, startedAt])
  @@index([metricName])
  @@map("anomaly_events")
}

model AnomalyModel {
  id             String   @id @default(uuid())
  serverId       String   @map("server_id")
  metricName     String   @map("metric_name")
  clusterCenters Json     @map("cluster_centers")
  threshold      Float
  trainedAt      DateTime @map("trained_at")
  expiresAt      DateTime @map("expires_at")
  dataPoints     Int      @map("data_points")
  modelVersion   Int      @default(1) @map("model_version")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, metricName])
  @@index([serverId, metricName])
  @@map("anomaly_models")
}

// ==================== ESCALATION POLICIES ====================

model EscalationPolicy {
  id        String   @id @default(uuid())
  name      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  steps EscalationStep[]

  @@map("escalation_policies")
}

model EscalationStep {
  id           String   @id @default(uuid())
  policyId     String   @map("policy_id")
  stepOrder    Int      @map("step_order")
  delayMinutes Int      @map("delay_minutes")
  channelId    String   @map("channel_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  policy  EscalationPolicy    @relation(fields: [policyId], references: [id], onDelete: Cascade)
  channel NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([policyId, stepOrder])
  @@index([channelId])
  @@map("escalation_steps")
}

// ==================== API TOKENS ====================

model ApiToken {
  id          String    @id @default(uuid())
  name        String
  tokenHash   String    @unique @map("token_hash")
  userId      String    @map("user_id")
  permissions Json      @default("[]")
  expiresAt   DateTime? @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  revoked     Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revoked])
  @@map("api_tokens")
}

// ==================== POST-MORTEMS ====================

model PostMortem {
  id          String    @id @default(uuid())
  incidentId  String    @unique @map("incident_id")
  summary     String
  rootCause   String    @map("root_cause")
  impact      String
  timeline    String
  actionItems Json      @default("[]") @map("action_items")
  createdBy   String?   @map("created_by")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@map("post_mortems")
}

// ==================== ALERT ROUTING RULES ====================

model AlertRoutingRule {
  id         String   @id @default(uuid())
  name       String
  enabled    Boolean  @default(true)
  priority   Int      @default(0)
  conditions Json     @default("{}")
  channelIds String[] @map("channel_ids")
  muteOthers Boolean  @default(false) @map("mute_others")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([enabled, priority])
  @@map("alert_routing_rules")
}

// ==================== SLA POLICIES ====================

model SlaPolicy {
  id              String   @id @default(uuid())
  name            String
  uptimeMonitorId String   @map("uptime_monitor_id")
  targetPercent   Float    @map("target_percent")
  windowDays      Int      @map("window_days")
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  uptimeMonitor UptimeMonitor @relation(fields: [uptimeMonitorId], references: [id], onDelete: Cascade)

  @@index([uptimeMonitorId])
  @@index([enabled])
  @@map("sla_policies")
}

// ==================== ALERT INHIBITION RULES ====================

model AlertInhibitionRule {
  id             String   @id @default(uuid())
  name           String
  sourceMatch    Json     @map("source_match")
  targetMatch    Json     @map("target_match")
  sourceSeverity String   @map("source_severity")
  targetSeverity String   @map("target_severity")
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("alert_inhibition_rules")
}

// ==================== ALERT GROUPS ====================

model AlertGroup {
  id          String    @id @default(uuid())
  name        String
  fingerprint String    @unique
  status      String    @default("active")
  alertCount  Int       @default(1) @map("alert_count")
  firstSeenAt DateTime  @map("first_seen_at")
  lastSeenAt  DateTime  @map("last_seen_at")
  resolvedAt  DateTime? @map("resolved_at")
  groupLabels Json      @map("group_labels")
  createdAt   DateTime  @default(now()) @map("created_at")

  alerts Alert[]

  @@index([status])
  @@map("alert_groups")
}

// ==================== STATUS PAGES ====================

model StatusPage {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String   @default("Service Status")
  description String?
  logoUrl     String?  @map("logo_url")
  customCss   String?  @map("custom_css")
  isPublic    Boolean  @default(true) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  components  StatusPageComponent[]
  subscribers StatusPageSubscriber[]

  @@map("status_pages")
}

model StatusPageComponent {
  id              String   @id @default(uuid())
  statusPageId    String   @map("status_page_id")
  name            String
  description     String?
  uptimeMonitorId String?  @map("uptime_monitor_id")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  statusPage StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)

  @@index([statusPageId])
  @@map("status_page_components")
}

model StatusPageSubscriber {
  id           String   @id @default(uuid())
  statusPageId String   @map("status_page_id")
  type         String   // EMAIL, WEBHOOK
  endpoint     String
  confirmed    Boolean  @default(false)
  confirmToken String?  @unique @map("confirm_token")
  createdAt    DateTime @default(now()) @map("created_at")

  statusPage StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)

  @@index([statusPageId])
  @@map("status_page_subscribers")
}

// ==================== ANNOTATIONS ====================

model Annotation {
  id        String    @id @default(uuid())
  title     String
  message   String?
  tags      String[]  @default([])
  startTime DateTime  @map("start_time")
  endTime   DateTime? @map("end_time")
  color     String    @default("#3B82F6")
  createdBy String?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([startTime])
  @@map("annotations")
}

// ==================== COMPOSITE MONITORS ====================

model CompositeMonitor {
  id          String   @id @default(uuid())
  name        String
  description String?
  expression  String
  monitorIds  String[] @map("monitor_ids")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("composite_monitors")
}

// ==================== MULTI-STEP MONITORS ====================

model MultiStepMonitor {
  id        String   @id @default(uuid())
  name      String
  interval  Int      @default(300)
  timeout   Int      @default(30)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  steps   MultiStepMonitorStep[]
  results MultiStepMonitorResult[]

  @@map("multi_step_monitors")
}

model MultiStepMonitorStep {
  id             String  @id @default(uuid())
  monitorId      String  @map("monitor_id")
  stepOrder      Int     @map("step_order")
  name           String
  method         String  @default("GET")
  url            String
  headers        Json?
  body           String?
  expectedStatus Int?    @map("expected_status")
  extractVars    Json?   @map("extract_vars")
  assertions     Json?

  monitor MultiStepMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, stepOrder])
  @@map("multi_step_monitor_steps")
}

model MultiStepMonitorResult {
  id          String   @id @default(uuid())
  monitorId   String   @map("monitor_id")
  status      String   // PASS, FAIL
  duration    Int      // total ms
  stepResults Json     @map("step_results")
  checkedAt   DateTime @default(now()) @map("checked_at")

  monitor MultiStepMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, checkedAt])
  @@map("multi_step_monitor_results")
}

// ==================== SCHEDULED REPORTS ====================

model ScheduledReport {
  id         String    @id @default(uuid())
  name       String
  type       String    // DAILY_SUMMARY, WEEKLY_SLA, MONTHLY_UPTIME
  schedule   String    // cron-like: "daily:08:00", "weekly:mon:09:00"
  recipients Json      // { emails: string[], channelIds: string[] }
  enabled    Boolean   @default(true)
  lastSentAt DateTime? @map("last_sent_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("scheduled_reports")
}

// ==================== SNMP DEVICES ====================

model SnmpDevice {
  id         String   @id @default(uuid())
  name       String
  host       String
  port       Int      @default(161)
  version    String   @default("2c")
  community  String?
  authConfig Json?    @map("auth_config")
  oids       Json     // Array of { oid, name, type }
  interval   Int      @default(60)
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  results SnmpPollResult[]

  @@map("snmp_devices")
}

model SnmpPollResult {
  id       String   @id @default(uuid())
  deviceId String   @map("device_id")
  values   Json
  polledAt DateTime @default(now()) @map("polled_at")

  device SnmpDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, polledAt])
  @@map("snmp_poll_results")
}

// ==================== RETENTION POLICIES ====================

model RetentionPolicy {
  id            String   @id @default(uuid())
  metricType    String   @unique @map("metric_type")
  retentionDays Int      @map("retention_days")
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("retention_policies")
}

// ==================== SERVICE DEPENDENCIES ====================

model ServiceDependency {
  id         String   @id @default(uuid())
  sourceId   String   @map("source_id")
  sourceType String   @map("source_type") // SERVER, MONITOR
  targetId   String   @map("target_id")
  targetType String   @map("target_type")
  label      String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([sourceId, targetId])
  @@map("service_dependencies")
}

// ==================== INFRASTRUCTURE CHANGES ====================

model InfraChange {
  id         String   @id @default(uuid())
  serverId   String?  @map("server_id")
  changeType String   @map("change_type") // PACKAGE_UPDATE, CONFIG_CHANGE, SERVICE_RESTART, DEPLOY
  source     String   // agent, webhook, manual
  title      String
  details    Json?
  detectedAt DateTime @map("detected_at")
  createdAt  DateTime @default(now()) @map("created_at")

  server Server? @relation(fields: [serverId], references: [id], onDelete: SetNull)

  @@index([serverId, detectedAt])
  @@index([detectedAt])
  @@map("infra_changes")
}

// ==================== ON-CALL SCHEDULES ====================

model OnCallSchedule {
  id        String   @id @default(uuid())
  name      String
  timezone  String   @default("UTC")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rotations OnCallRotation[]

  @@map("on_call_schedules")
}

model OnCallRotation {
  id         String   @id @default(uuid())
  scheduleId String   @map("schedule_id")
  userId     String   @map("user_id")
  startTime  DateTime @map("start_time")
  endTime    DateTime @map("end_time")

  schedule OnCallSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId, startTime])
  @@map("on_call_rotations")
}

// ==================== SLO TRACKING ====================

model Slo {
  id              String   @id @default(uuid())
  name            String
  description     String?
  targetPercent   Float    @map("target_percent")
  windowDays      Int      @map("window_days")
  uptimeMonitorId String?  @map("uptime_monitor_id")
  metricQuery     String?  @map("metric_query")
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("slos")
}

// ==================== OPENTELEMETRY TRACES ====================

model OtlpSpan {
  id            String   @id @default(uuid())
  traceId       String   @map("trace_id")
  spanId        String   @map("span_id")
  parentSpanId  String?  @map("parent_span_id")
  operationName String   @map("operation_name")
  serviceName   String   @map("service_name")
  startTime     DateTime @map("start_time")
  duration      BigInt
  status        String   @default("OK")
  attributes    Json?
  events        Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([traceId])
  @@index([serviceName, startTime])
  @@index([startTime])
  @@map("otlp_spans")
}

// ==================== RUNBOOKS ====================

model Runbook {
  id          String   @id @default(uuid())
  name        String
  description String?
  script      String
  language    String   @default("bash")
  timeout     Int      @default(300)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  executions     RunbookExecution[]
  alertTemplates AlertTemplate[]

  @@map("runbooks")
}

model RunbookExecution {
  id          String    @id @default(uuid())
  runbookId   String    @map("runbook_id")
  alertId     String?   @map("alert_id")
  serverId    String?   @map("server_id")
  status      String    // PENDING, RUNNING, SUCCESS, FAILED, TIMEOUT
  output      String?
  exitCode    Int?      @map("exit_code")
  startedAt   DateTime  @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  triggeredBy String?   @map("triggered_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  runbook Runbook @relation(fields: [runbookId], references: [id], onDelete: Cascade)

  @@index([runbookId, startedAt])
  @@map("runbook_executions")
}

// ==================== REAL USER MONITORING ====================

model RumSession {
  id        String   @id @default(uuid())
  sessionId String   @unique @map("session_id")
  userAgent String?  @map("user_agent")
  country   String?
  startedAt DateTime @map("started_at")
  createdAt DateTime @default(now()) @map("created_at")

  pageViews RumPageView[]

  @@index([startedAt])
  @@map("rum_sessions")
}

model RumPageView {
  id               String   @id @default(uuid())
  sessionId        String   @map("session_id")
  url              String
  loadTime         Int?     @map("load_time")
  domContentLoaded Int?     @map("dom_content_loaded")
  firstPaint       Int?     @map("first_paint")
  lcp              Int?
  fid              Int?
  cls              Float?
  errorCount       Int      @default(0) @map("error_count")
  viewedAt         DateTime @map("viewed_at")

  session RumSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId])
  @@index([viewedAt])
  @@map("rum_page_views")
}

// ==================== KUBERNETES ====================

model KubernetesCluster {
  id          String    @id @default(uuid())
  name        String
  apiEndpoint String    @map("api_endpoint")
  authConfig  Json      @map("auth_config")
  enabled     Boolean   @default(true)
  lastSyncAt  DateTime? @map("last_sync_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("kubernetes_clusters")
}

// ==================== SYNTHETIC CHECKS ====================

model SyntheticCheck {
  id        String   @id @default(uuid())
  name      String
  script    String
  interval  Int      @default(300)
  timeout   Int      @default(60)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  results SyntheticCheckResult[]

  @@map("synthetic_checks")
}

model SyntheticCheckResult {
  id           String    @id @default(uuid())
  checkId      String    @map("check_id")
  status       String    // PASS, FAIL, TIMEOUT
  duration     Int
  screenshot   String?
  errorMessage String?   @map("error_message")
  stepResults  Json?     @map("step_results")
  checkedAt    DateTime  @default(now()) @map("checked_at")

  check SyntheticCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)

  @@index([checkId, checkedAt])
  @@map("synthetic_check_results")
}
