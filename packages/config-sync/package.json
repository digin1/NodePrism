{
  "name": "@nodeprism/config-sync",
  "version": "1.0.0",
  "private": true,
  "description": "Configuration sync worker",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/index.ts",
    "build": "tsc",
    "start": "NODE_ENV=production node dist/index.js",
    "clean": "rm -rf dist",
    "prisma:generate": "prisma generate --schema=../api/prisma/schema.prisma"
  },
  "dependencies": {
    "@nodeprism/shared": "workspace:*",
    "@prisma/client": "^5.8.1",
    "axios": "^1.13.6",
    "dotenv": "^16.4.1",
    "pg": "^8.11.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/pg": "^8.10.9",
    "nodemon": "^3.0.3",
    "prisma": "^5.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
