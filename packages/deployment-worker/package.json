{
  "name": "@nodeprism/deployment-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Agent deployment service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/index.ts",
