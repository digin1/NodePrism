    "dotenv": "^16.4.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/ssh2": "^1.11.18",
    "@types/amqplib": "^0.10.4",
    "nodemon": "^3.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
